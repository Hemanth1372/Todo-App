# Railway Backend Environment Variables
# Update these values when deploying

# Server
PORT=5000
NODE_ENV=production

# Database (will be auto-generated by Railway)
# DATABASE_URL=postgresql://user:password@host:port/todo_app

# Security - CHANGE THIS TO A RANDOM SECURE STRING!
JWT_SECRET=change-this-to-a-random-secure-string-in-production

# Frontend URL (update with your Vercel frontend URL)
# FRONTEND_URL=https://your-todo-app.vercel.app
